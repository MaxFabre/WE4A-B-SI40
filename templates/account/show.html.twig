{% extends 'base.html.twig' %}

{% block title %}Profil de {{ user.username }}{% endblock %}

{% set view_all = app.user and app.user==user or is_granted('ROLE_MODERATOR') or is_granted('ROLE_FUND_MANAGER') or is_granted('ROLE_ADMIN') %}

{% block container %}
    <div class="row person">
        <div class="col-md-3 col-sm-12 person-info">
            <img class="" src="{{ asset(path=user.person.photo , packageName = 'profil_pictures') }}" alt="Image de profile"/>
            <div class="">
                <div class="d-flex justify-content-between align-self-center">
                    <h1>{{ user.username }}</h1>
                    {% if app.user and app.user==user %}
                        <a href="{{ url('account.edit', parameters = {id: app.user.id}) }}">{{ ux_icon('setting') }}</a>
                    {% endif %}
                </div>
                {% if view_all %}
                    <h2>{{ user.person.firstname }} {{ user.person.lastname }}</h2>
                {% endif %}
                <p>A rejoint le {{ user.person.createdAt|date('d/m/y') }}</p>
            </div>
        </div>

        <div class="col-md-9 col-sm-12">

            <h1>Réservations</h1>
            <div class="table-reservations">

                <table class="table">

                    <tr><th></th><th>Film</th><th>Date</th><th>Nombre de places</th><th></th></tr>

                    {% for basket in user.baskets %}
                        {% if ((not basket.isActive) and (basket.status == "paid")) %}
                            {% for reservation in basket.reservations %}
                                <tr>
                                    <td class="imagePreview"> <img src="{{ asset(path=reservation.programme.film.coverPath, packageName='films_cover') }}" alt="affiche du film" class="imagePreview"/></td>
                                    <td class="column-wrap">{{ reservation.programme.film.title }} </td>
                                    <td class="column-wrap">{{ reservation.programme.date ? reservation.programme.date|date('d/m/Y') }} <br>de {{ reservation.programme.date ? reservation.programme.date|date('H:i') : ''}} à {{ reservation.programme.date ? reservation.programme.date|date_modify('+' ~ reservation.programme.film.duration ~ ' minutes')|date('H:i') : '' }}</td>
                                    <td class="column-wrap">{{ reservation.seats|length }}</td>
                                    <td class="column-wrap">
                                        <div class="d-flex justify-content-evenly">
                                            <a class="btn btn-danger" href="{{ url('account.ticket', {id: reservation.id}) }}">
                                                Voir le ticket
                                            </a>
                                        </div>
                                    </td>
                                </tr>

                            {% endfor %}
                        {% endif %}
                    {% endfor %}
                </table>

            </div>
            <hr/>


            {% if view_all %}
                <h1>Films vues</h1>
                <div class="table-reservations">

                    <table class="table">

                        <tr><th></th><th>Film</th><th>Date</th><th>Nombre de places</th></tr>

                        {% for basket in user.baskets %}
                            {% if ((not basket.isActive) and (basket.status == "paid")) %}
                                {% for reservation in basket.reservations %}
                                    {% if (reservation.programme.date<date()) %}
                                        <tr>
                                            <td class="imagePreview"> <img src="{{ asset(path=reservation.programme.film.coverPath, packageName='films_cover') }}" alt="affiche du film" class="imagePreview"/></td>
                                            <td class="column-wrap">{{ reservation.programme.film.title }} </td>
                                            <td class="column-wrap">{{ reservation.programme.date ? reservation.programme.date|date('d/m/Y') }} <br>de {{ reservation.programme.date ? reservation.programme.date|date('H:i') : ''}} à {{ reservation.programme.date ? reservation.programme.date|date_modify('+' ~ reservation.programme.film.duration ~ ' minutes')|date('H:i') : '' }}</td>
                                            <td class="column-wrap">{{ reservation.seats|length }}</td>
                                        </tr>
                                    {%endif%}

                                {% endfor %}
                            {% endif %}
                        {% endfor %}
                    </table>

                </div>
            {% endif %}




            <div>
                <h1>Commentaires</h1>
                <table class="table">
                    <tr><th>Film</th><th>Titre</th><th>Note</th></tr>
                    {% for comment in user.getComments %}
                        <tr>
                            <td><a href="{{ url('film.show', parameters = {slug: comment.film.slug}) }}">{{ comment.film.title }}</a></td>
                            <td><a href="{{ url('film.show', parameters = {slug: comment.film.slug}) }}">{{ comment.title }}</a></td>
                            <td><a href="{{ url('film.show', parameters = {slug: comment.film.slug}) }}">{{ comment.note }}/20</a></td>
                        </tr>
                    {% endfor %}
                </table>
            </div>
        </div>
    </div>
{% endblock %}
