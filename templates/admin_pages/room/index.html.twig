{% extends 'admin_pages/base.html.twig' %}

{% block title %}Outils - Salle{% endblock %}

{% block main %}
    <h1>Salles :</h1>
    <div class="row">

        <div class="horizontal col-md-12 col-sm-12 col-lg-6">

            <div class="partie-droite">
                <form method="get" class="my-3">
                    <label for="sortRoom" class="form-label">Trier les salles</label>
                    <select id="sortRoom" name="sortRoom" class="form-select" onchange="this.form.submit()">
                        <option value="id_asc" {{ sortRoom == 'id_asc' ? 'selected' : '' }}>Id croissante</option>
                        <option value="id_desc" {{ sortRoom == 'id_desc' ? 'selected' : '' }}>Id décroissante</option>
                        <option value="capacity_asc" {{ sortRoom == 'capacity_asc' ? 'selected' : '' }}>Capacité croissante</option>
                        <option value="capacity_desc" {{ sortRoom == 'capacity_desc' ? 'selected' : '' }}>Capacité décroissante</option>
                    </select>
                </form>
            </div>

            <div class="partie-gauche">
                <a class="btn btn-primary" href="{{ url('admin.room.create') }}">Nouvelle Salle</a>
            </div>
        </div>


        <table class="table table-striped col-md-12 col-sm-12 col-lg-6">
            <tr><th>ID</th><th>Nom</th><th>Capacité</th><th>Actions</th></tr>
            {% for room in rooms %}
                <tr>
                    <td>{{ room.id }}</td>
                    <td>{{ room.name }}</td>
                    <td>{{ room.capacity }}</td>
                    <td>
                        <div class="d-flex justify-content-evenly">
                            <a class="btn btn-primary" id="edit" href="{{ url('admin.room.edit', parameters = {id: room.id} ) }}">Éditer</a>
                            <form method="post" action="{{ url('admin.room.delete', {id: room.id}) }}">
                                <input type="hidden" name="_method" value="DELETE"/>
                                <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ room.id) }}">
                                <input class="btn btn-danger" type="submit" value="Supprimer"/>
                            </form>
                        </div>
                    </td>
                </tr>
            {% endfor %}
        </table>
    </div>
{% endblock %}
