<div id="carouselExampleIndicators" class="carousel slide" data-bs-ride="carousel">

    <div class="carousel-indicators">
        {% for item in pinnedFilms %}
            <button type="button" data-bs-target="#carouselExampleIndicators" data-bs-slide-to="{{ loop.index-1 }}" class="{% if loop.index==1 %}active{% endif %}"></button>
        {% endfor %}
    </div>

    <div class="carousel-inner carousel-frame">
        {% for item in pinnedFilms %}
            <div class="carousel-item {% if loop.index==1 %}active{% endif %}">
                <div class="film-pined">
                    <a href="{{ url('film.show', parameters = {slug: item.film.slug}) }}"><img src="{{ asset(path=item.film.coverPath, packageName = 'films_cover') }}" alt="Affiche du film {{ item.film.title }}"/></a>
                    <div>
                        <h2><a href="{{ url('film.show', parameters = {slug: item.film.slug}) }}">{{ item.film.title }}</a></h2>
                        {% set hours = (item.film.duration // 60) %}
                        {% set mins = (item.film.duration % 60) %}
                        <strong>{{ ux_icon('horloge') }} {{ hours }}h{{ mins }} </strong>
                        <p>{{ item.film.description }}</p>
                        <div class="film-pined-genre">
                            {% for genre in item.film.genre %}
                            <span>{{ genre.name }}</span>
                            {% endfor %}
                        </div>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>

    <button class="carousel-control-prev" type="button" data-bs-target="#carouselExampleIndicators" data-bs-slide="prev">
        <span class="carousel-control-prev-icon"></span>
    </button>

    <button class="carousel-control-next" type="button" data-bs-target="#carouselExampleIndicators" data-bs-slide="next">
        <span class="carousel-control-next-icon"></span>
    </button>

</div>
